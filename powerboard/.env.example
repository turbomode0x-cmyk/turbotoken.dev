# Turbo Token - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Required: Google Gemini API Key for AI token analysis
# Get your key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Required: Your Solana wallet address for receiving tips
# Users can tip any amount via Solana Pay URI
VITE_TIP_WALLET=YOUR_SOLANA_WALLET_ADDRESS_HERE

# Required: Trojan bot affiliate template for snipe links
# Template should include {ca} placeholder for token contract address
# Example: https://t.me/YOUR_TROJAN_BOT?start=YOUR_AFF_CODE-{ca}
VITE_SNIPE_BOT_TEMPLATE=https://t.me/YOUR_TROJAN_BOT?start=YOUR_AFF_CODE-{ca}
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_TIP_WALLET=
VITE_SNIPE_BOT_TEMPLATE=https://t.me/YOUR_TROJAN_BOT?start=YOUR_AFF_CODE-{ca}
